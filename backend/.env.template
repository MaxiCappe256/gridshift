# Copia a .env y ajusta si hace falta.
# Con DB en Docker (este repo): el puerto en el HOST es 5445 (ver docker-compose.yml).
NODE_ENV=development
DATABASE_HOST=localhost
DATABASE_PORT=5445
DATABASE_NAME=gripshift_local
DATABASE_USER=user_dev
DATABASE_PASS=password_dev
PORT=3000

# TypeORM
# synchronize should stay false in production; enable only for one-off bootstrap.
# TYPEORM_SYNCHRONIZE=false

# (Opcional) Protege POST /seed en dev con un token
# SEED_TOKEN=changeme
